# ── DATABASE (Supabase Postgres) ────────────────────────────────────
# From Supabase: Project Settings → Database → Connection string
# Use the "Transaction" pooler (port 6543) for DATABASE_URL — this is
# what your serverless Next.js app uses at runtime.
DATABASE_URL="postgresql://postgres.xxxxxxxx:YOUR_PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Use the "Session" pooler (port 5432) or the direct connection for
# DIRECT_URL — Prisma Migrate needs this one for running migrations.
DIRECT_URL="postgresql://postgres.xxxxxxxx:YOUR_PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres"

# ── NEXTAUTH (Admin login) ──────────────────────────────────────────
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-real-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# ── SEED SCRIPT (creates your first admin login) ────────────────────
# These are only read by `npm run db:seed` — set them, run the seed
# once, then you can remove them or change the password from /admin.
SEED_ADMIN_EMAIL="you@emunahh.com"
SEED_ADMIN_PASSWORD="choose-a-strong-password"
SEED_ADMIN_NAME="Emunahh Admin"

# ── ONE-TIME LIVE SEED ENDPOINT ──────────────────────────────────────
# Lets you seed the production database by visiting a URL — no local
# terminal needed. Set to any long random string, deploy, then visit:
#   https://your-domain.com/api/admin/seed?secret=THIS_VALUE
# Safe to leave set afterward (it's a no-op without hitting the route).
SEED_SECRET="choose-another-long-random-string"

# ── CLOUDINARY (image uploads — optional for now) ───────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=""
